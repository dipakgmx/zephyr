# Bluetooth GATT Authorization Control Service

config BT_ACS
	bool "GATT Authorization Control Service"
	depends on BT_CONN
	depends on MBEDTLS_PSA_CRYPTO_C
	depends on BT_SMP
	select EXPERIMENTAL
	help
	  Enable GATT Authorization Control Service (UUID 0x183D).
	  This service provides rigorous application-level security for BLE resources,
	  requiring an Authorization Control (AC) Client to successfully authenticate
	  to access specific, protected GATT resources of an AC Server.

if BT_ACS

module = BT_ACS
module-str = BT_ACS
source "subsys/logging/Kconfig.template.log_config"

menu "ACS Protection Methods"

menuconfig BT_ACS_FEAT_AUTHORIZATION
	bool "Authorization support (Restriction Maps)"
	default y
	help
	  Enable Restriction Map support for ACS-protected resources.
	  This exposes the Get Restriction Map Descriptor (0x02) and
	  Get Restriction Map ID List (0x04) procedures so an AC Client
	  can discover how protected resources and procedures map to
	  Information Security Configuration IDs.
	  If disabled, that mapping is not discoverable through the
	  standard ACS Restriction Map procedures and would need to be
	  known by other means.

if BT_ACS_FEAT_AUTHORIZATION

config BT_ACS_ACTIVE_RMAP_ID
	int "Protected Restriction Map ID"
	default 1
	range 1 65535
	help
	  Identifier of the active protected Restriction Map.
	  AC Clients can cache Restriction Map content by Restriction
	  Map ID and re-read it when the ID changes.
	  Value 0 is reserved by the specification for the native-service
	  access map, where resources are accessed through their own GATT
	  service rather than through ACS mediation.

endif # BT_ACS_FEAT_AUTHORIZATION

config BT_ACS_FEAT_AUTHENTICATION
	bool "Authentication support"
	default y
	help
	  Enable support for authentication-related information security
	  controls in this ACS implementation.

config BT_ACS_FEAT_INTEGRITY
	bool "Integrity support"
	depends on BT_ACS_FEAT_AUTHENTICATION
	default y
	help
	  Enable support for integrity-related information security
	  controls in this ACS implementation. In this implementation,
	  integrity support is available only when authentication
	  support is enabled.

config BT_ACS_FEAT_CONFIDENTIALITY
	bool "Confidentiality support"
	depends on BT_ACS_FEAT_INTEGRITY
	default y
	help
	  Enable support for confidentiality-related information security
	  controls in this ACS implementation. In this implementation,
	  confidentiality support is available only when integrity
	  support is enabled.

endmenu # ACS Protection Methods

menuconfig BT_ACS_KEY_EXCHANGE_ECDH
	bool "ECDH key exchange"
	depends on PSA_WANT_ALG_ECDH
	depends on PSA_WANT_ALG_HKDF
	depends on PSA_WANT_ALG_SHA_256
	depends on PSA_WANT_KEY_TYPE_DERIVE
	depends on BT_SETTINGS
	depends on BT_ACS_FEAT_AUTHENTICATION
	default y if BT_ACS_FEAT_AUTHENTICATION
	help
	  Enable Elliptic Curve Diffie-Hellman (ECDH) key exchange for
	  this ACS implementation.

	  Deriving the 128-bit ECDHKey from the ECDH shared secret via a
	  KDF is an integral part of this method (ACS 1.0 §3.6.4.2), as is
	  the HMAC-SHA-256 confirmation code - hence the HKDF and SHA-256
	  dependencies. This is distinct from the standalone KDF Key
	  Exchange method (BT_ACS_KEY_EXCHANGE_KDF), which is optional.

	  For Authorization Control Profile 1.0 §4.1.1.1 compliance, ECDH
	  support requires Curve P-256 with HKDF SHA-256 128-bit - the
	  defaults of this implementation.

	  In this implementation, ECDH key exchange depends on PSA Crypto
	  ECDH support and BT_SETTINGS for persistent ACS key material.
	  On platforms that do not provide TF-M-backed persistent key
	  storage, SECURE_STORAGE may also be needed for the PSA Crypto
	  persistent key backend.

if BT_ACS_KEY_EXCHANGE_ECDH

choice BT_ACS_ECDH_CURVE
	prompt "ECDH curve"
	default BT_ACS_ECDH_CURVE_P256
	help
	  Select the elliptic curve used by ECDH key exchange in this
	  implementation.

	  Authorization Control Profile 1.0 §4.1.1.1 requires Curve P-256
	  for profile-compliant ECDH support; the other curves are
	  implementation extensions.

	  The available choices depend on the enabled PSA Crypto ECC
	  capabilities.

config BT_ACS_ECDH_CURVE_P256
	bool "Curve P-256 (secp256r1)"
	depends on PSA_WANT_ECC_SECP_R1_256

config BT_ACS_ECDH_CURVE_P384
	bool "Curve P-384 (secp384r1)"
	depends on PSA_WANT_ECC_SECP_R1_384

config BT_ACS_ECDH_CURVE_P521
	bool "Curve P-521 (secp521r1)"
	depends on PSA_WANT_ECC_SECP_R1_521

config BT_ACS_ECDH_CURVE_CURVE25519
	bool "Curve25519"
	depends on PSA_WANT_ECC_MONTGOMERY_255

endchoice

endif # BT_ACS_KEY_EXCHANGE_ECDH

# Hidden symbol for coordinate size - always present so C code compiles when ECDH is off.
config BT_ACS_ECDH_COORD_SIZE
	int
	default 66 if BT_ACS_ECDH_CURVE_P521
	default 48 if BT_ACS_ECDH_CURVE_P384
	default 32

# Hidden symbol for Y-axis presence (1 = yes, 0 = no) - always present.
config BT_ACS_ECDH_HAS_Y
	int
	default 0 if BT_ACS_ECDH_CURVE_CURVE25519
	default 1

# Shared secret buffer size - sized to the ECDH curve when ECDH is enabled;
# 32 bytes otherwise.
config BT_ACS_SHARED_SECRET_MAX_SIZE
	int
	default 66 if BT_ACS_ECDH_CURVE_P521
	default 48 if BT_ACS_ECDH_CURVE_P384
	default 32

menuconfig BT_ACS_KEY_EXCHANGE_KDF
	bool "Key Derivation Function key exchange"
	depends on PSA_WANT_ALG_HKDF
	depends on PSA_WANT_KEY_TYPE_DERIVE
	depends on BT_SETTINGS
	depends on BT_ACS_FEAT_AUTHENTICATION
	help
	  Enable the standalone Key Derivation Function (KDF) key exchange
	  method (ACS 1.0 §3.6.4.3), which derives a child key from an
	  already-established ECDH parent key.

	  This is a separate, optional ACS method - it is not required for
	  ECDH key exchange, whose own in-method KDF step is always
	  available with BT_ACS_KEY_EXCHANGE_ECDH.

	  In this implementation, KDF key exchange depends on BT_SETTINGS
	  for persistent ACS key material. The derived child key is
	  connection-specific runtime state and is derived again when a
	  new connection is established.

if BT_ACS_KEY_EXCHANGE_KDF || BT_ACS_KEY_EXCHANGE_ECDH

choice BT_ACS_KDF_ALGORITHM
	prompt "Key Derivation Function algorithm"
	default BT_ACS_KDF_HKDF_SHA256
	help
	  Select the HKDF algorithm used for ACS session key derivation -
	  both for the KDF step inside ECDH key exchange and for the
	  standalone KDF Key Exchange method.

	  Authorization Control Profile 1.0 §4.1.1.1 requires HKDF SHA-256
	  128-bit (the default) for profile-compliant ECDH support; the
	  other variants are implementation extensions.

config BT_ACS_KDF_HKDF_SHA256
	bool "HKDF SHA-256 128-bit"
	depends on PSA_WANT_ALG_SHA_256

config BT_ACS_KDF_HKDF_SHA256_WITH_INFO
	bool "HKDF SHA-256 128-bit With Additional KDF Info Concatenation"
	depends on PSA_WANT_ALG_SHA_256

config BT_ACS_KDF_HKDF_SHA384
	bool "HKDF SHA-384 128-bit"
	depends on PSA_WANT_ALG_SHA_384

config BT_ACS_KDF_HKDF_SHA384_WITH_INFO
	bool "HKDF SHA-384 128-bit With Additional KDF Info Concatenation"
	depends on PSA_WANT_ALG_SHA_384

config BT_ACS_KDF_HKDF_SHA512
	bool "HKDF SHA-512 128-bit"
	depends on PSA_WANT_ALG_SHA_512

config BT_ACS_KDF_HKDF_SHA512_WITH_INFO
	bool "HKDF SHA-512 128-bit With Additional KDF Info Concatenation"
	depends on PSA_WANT_ALG_SHA_512

endchoice

config BT_ACS_HAS_INFO_FOR_HKDF
	bool
	default y if BT_ACS_KDF_HKDF_SHA256_WITH_INFO || \
	             BT_ACS_KDF_HKDF_SHA384_WITH_INFO || \
	             BT_ACS_KDF_HKDF_SHA512_WITH_INFO
	default n

endif # BT_ACS_KEY_EXCHANGE_KDF || BT_ACS_KEY_EXCHANGE_ECDH

# KDF buffer sizes - always present so C code compiles when KDF is off.
config BT_ACS_KDF_SALT_MAX_SIZE
	int
	default 64 if BT_ACS_KDF_HKDF_SHA512 || BT_ACS_KDF_HKDF_SHA512_WITH_INFO
	default 48 if BT_ACS_KDF_HKDF_SHA384 || BT_ACS_KDF_HKDF_SHA384_WITH_INFO
	default 32

config BT_ACS_KDF_INFO_MAX_SIZE
	int
	default 64 if BT_ACS_KDF_HKDF_SHA512_WITH_INFO
	default 48 if BT_ACS_KDF_HKDF_SHA384_WITH_INFO
	default 32 if BT_ACS_KDF_HKDF_SHA256_WITH_INFO
	default 0

menu "Confirmation Capabilities"

config BT_ACS_CONFIRMATION_OUTPUT_NUMERIC
	bool "Numeric output display"
	help
	  Advertise support for numeric output OOB confirmation
	  (BIT(3) of Confirmation_Output_OOB_Number_Capabilities).

	  In this implementation, use this option when
	  bt_acs_cb.output_oob_number is provided
	  (see <zephyr/bluetooth/services/acs.h>).

config BT_ACS_CONFIRMATION_OUTPUT_MAX_VALUE
	int
	prompt "Maximum output numeric value" if BT_ACS_CONFIRMATION_OUTPUT_NUMERIC
	default 999999 if BT_ACS_CONFIRMATION_OUTPUT_NUMERIC
	default 0
	range 1 999999999 if BT_ACS_CONFIRMATION_OUTPUT_NUMERIC
	help
	  Maximum numeric value the AC Server can display for
	  confirmation.

	  This value is reported in
	  Confirmation_Output_OOB_Number_Max_Value in the Feature
	  Response. When numeric output is disabled, this symbol
	  defaults to 0 so it remains defined.

config BT_ACS_CONFIRMATION_OUTPUT_BEEP
	bool "Output beep"
	help
	  Advertise support for beep output OOB confirmation
	  (BIT(1) of Confirmation_Output_OOB_Number_Capabilities).

	  In this implementation, use this option when
	  bt_acs_cb.output_oob_number is provided
	  (see <zephyr/bluetooth/services/acs.h>).

config BT_ACS_CONFIRMATION_INPUT_NUMERIC
	bool "Numeric input"
	help
	  Advertise support for numeric input OOB confirmation
	  (BIT(2) of Confirmation_Input_OOB_Number_Capabilities).

	  In this implementation, use this option when
	  bt_acs_cb.input_oob_request is provided
	  (see <zephyr/bluetooth/services/acs.h>).

config BT_ACS_CONFIRMATION_INPUT_MAX_VALUE
	int
	prompt "Maximum input numeric value" if BT_ACS_CONFIRMATION_INPUT_NUMERIC
	default 999999 if BT_ACS_CONFIRMATION_INPUT_NUMERIC
	default 0
	range 1 999999999 if BT_ACS_CONFIRMATION_INPUT_NUMERIC
	help
	  Maximum numeric value the AC Server can accept as
	  confirmation input.

	  This value is reported in
	  Confirmation_Input_OOB_Number_Max_Value in the Feature
	  Response. When numeric input is disabled, this symbol
	  defaults to 0 so it remains defined.

config BT_ACS_CONFIRMATION_INPUT_PUSH
	bool "Push input"
	help
	  Advertise support for push input OOB confirmation
	  (BIT(0) of Confirmation_Input_OOB_Number_Capabilities).

	  In this implementation, use this option when
	  bt_acs_cb.input_oob_request is provided
	  (see <zephyr/bluetooth/services/acs.h>).

endmenu # Confirmation Capabilities

menu "Security Management Procedures"

config BT_ACS_INVALIDATE_ESTABLISHED_SECURITY
	bool
	default y if BT_ACS_ANY_KEY_EXCHANGE
	help
	  Enable support for the Invalidate All Established Security
	  and Invalidate Key procedures.

	  Per Authorization Control Service 1.0, Section 4.4.1,
	  Table 4.13, these procedures are required when the
	  corresponding key-exchange and invalidation capabilities
	  are supported.

	  This symbol is not user-selectable and is enabled
	  automatically when required by the selected ACS features.

config BT_ACS_ABORT
	bool
	default y if BT_ACS_DESCRIPTORS || BT_ACS_ANY_KEY_EXCHANGE
	help
	  Enable support for the Abort procedure used to terminate
	  an in-progress ACS operation.

	  Per Authorization Control Service 1.0, Section 4.4.1,
	  Table 4.13, Abort is required when descriptor reporting
	  or key exchange is supported.

	  This symbol is not user-selectable and is enabled
	  automatically when required by the selected ACS features.

config BT_ACS_SET_SECURITY_CONTROLS_SWITCH
	bool "Set Security Controls Switch procedure"
	default n
	help
	  Enable support for the Set Security Controls Switch
	  procedure.

	  This procedure allows an AC Client to change the state
	  of the security controls switch.

	  Disable this option unless your implementation has a clear
	  access-control model for this procedure. If exposed without
	  appropriate protection, it can reduce the effectiveness of
	  ACS-enforced security controls.

config BT_ACS_INITIATE_PAIRING
	bool "Initiate Pairing procedure"
	default n
	help
	  Enable support for the Initiate Pairing procedure.

	  When enabled, an AC Client can request that the AC Server
	  initiate Bluetooth LE pairing through the local connection
	  security API.

	  This option sets the Initiation of Pairing Supported bit
	  in the ACS Feature Response.

endmenu # Security Management Procedures

# Hidden: AES session key length in bytes. Fixed at 16 because every currently
# supported data-protection algorithm (AES-CCM, AES-GCM, AES-GMAC, AES-CMAC)
# uses AES-128. A future AES-256 variant would flip this to 32.
config BT_ACS_SESSION_KEY_SIZE
	int
	default 16

menu "Data protection algorithms"
	depends on BT_ACS_FEAT_AUTHENTICATION

config BT_ACS_DATA_PROTECTION_AES_GCM
	bool "AES-128-GCM (AEAD)"
	default y if BT_ACS_FEAT_CONFIDENTIALITY
	depends on BT_ACS_FEAT_CONFIDENTIALITY
	select PSA_WANT_ALG_GCM
	select PSA_WANT_KEY_TYPE_AES
	help
	  AES-128-GCM provides authenticated encryption with associated
	  data (AEAD) and can be used when protected resources require
	  confidentiality, integrity, and authentication.

	  Uses a 12-octet IV: 4-octet fixed part and 8-octet variable
	  invocation part, as recommended by the ACS specification.

	  This is the baseline authenticated-encryption algorithm for
	  ACS confidentiality support.

config BT_ACS_DATA_PROTECTION_AES_CCM
	bool "AES-128-CCM (AEAD)"
	depends on BT_ACS_FEAT_CONFIDENTIALITY
	select PSA_WANT_ALG_CCM
	select PSA_WANT_KEY_TYPE_AES
	help
	  AES-128-CCM is an authenticated-encryption with associated
	  data (AEAD) algorithm. This implementation supports
	  configurable MAC size and nonce format through the
	  associated Kconfig options.

	  Nonce state is maintained per key descriptor record.

config BT_ACS_DATA_PROTECTION_AES_GMAC
	bool "AES-128-GMAC (integrity)"
	default y if BT_ACS_FEAT_INTEGRITY
	depends on BT_ACS_FEAT_INTEGRITY
	select PSA_WANT_ALG_GCM
	select PSA_WANT_KEY_TYPE_AES
	help
	  AES-128-GMAC provides authentication and integrity without
	  confidentiality and can be used when protected resources do
	  not require encryption.

	  Uses the same 12-octet IV structure as AES-128-GCM.

config BT_ACS_DATA_PROTECTION_AES_CMAC
	bool "AES-128-CMAC (authentication)"
	depends on BT_ACS_FEAT_AUTHENTICATION
	select PSA_WANT_ALG_CMAC
	select PSA_WANT_KEY_TYPE_AES
	help
	  AES-128-CMAC provides authentication without nonce-based
	  integrity or confidentiality protection. Can be enabled
	  alongside other algorithms when authentication-only ISC
	  configurations are needed.

endmenu

config BT_ACS_CCM_MAC_SIZE
	int "AES-CCM MAC tag size in bytes"
	default 8
	range 4 16
	depends on BT_ACS_DATA_PROTECTION_AES_CCM
	help
	  Size, in bytes, of the authentication tag generated by
	  AES-128-CCM.

	  Valid values are even numbers from 4 to 16. This value is
	  reported in the MAC_Size field of the ACS key descriptor.

choice BT_ACS_CCM_NONCE_TYPE
	prompt "AES-CCM nonce type"
	default BT_ACS_CCM_NONCE_SEQ_DIFF_FIXED
	depends on BT_ACS_DATA_PROTECTION_AES_CCM
	help
	  Select the nonce format advertised for AES-128-CCM in this
	  implementation.

	  This implementation uses an 8-octet runtime counter. When
	  the selected nonce format requires additional nonce octets,
	  the remaining prefix bytes are derived from established
	  key material.

config BT_ACS_CCM_NONCE_SEQ_DIFF_FIXED
	bool "Sequence Number Different Fixed Parts (0x02)"
	help
	  Use the Sequence Number Different Fixed Parts nonce format
	  for AES-128-CCM.

	  In this implementation, distinct server and client fixed
	  nonce prefixes are derived before protected traffic begins,
	  and the variable part is carried by the runtime counter.

config BT_ACS_CCM_NONCE_FIXED_SIZE
	int "Fixed nonce part size in bytes (AES-CCM, SEQ_DIFF_FIXED)"
	default 8
	range 5 12
	depends on BT_ACS_CCM_NONCE_SEQ_DIFF_FIXED
	help
	  Size, in bytes, of the fixed nonce part advertised for
	  AES-128-CCM when using the Sequence Number Different Fixed
	  Parts format.

	  The remaining nonce octets are used for the variable part.
	  ACS allows the fixed and variable parts together to total
	  13 octets, with each part at least 1 octet.

	  This implementation limits the variable part to at most
	  8 octets, so the supported fixed-part range is 5 to
	  12 octets.

config BT_ACS_CCM_NONCE_SEQ_EVEN_ODD
	bool "Sequence Number Even-Odd (0x01)"
	help
	  Use the Sequence Number Even-Odd nonce format for
	  AES-128-CCM.

	  In this mode, the server uses even sequence numbers and
	  the client uses odd sequence numbers. This implementation
	  derives the shared nonce prefix from established key
	  material and appends the even-or-odd counter value at
	  runtime.

endchoice

config BT_ACS_KEX_CTX_COUNT
	int "Concurrent key-exchange contexts"
	depends on BT_ACS_ANY_KEY_EXCHANGE
	range 1 BT_MAX_CONN
	default 1
	help
	  Number of key exchanges that can run concurrently across all
	  connections. A context is pool-allocated when Start Key Exchange
	  is accepted and released when the exchange completes or aborts,
	  so connections carry only a pointer instead of the full
	  transcript state.

# Hidden helpers - derived from active selections, used for CMakeLists gating.
config BT_ACS_ANY_KEY_EXCHANGE
	bool
	default y if BT_ACS_KEY_EXCHANGE_ECDH || BT_ACS_KEY_EXCHANGE_KDF

config BT_ACS_ANY_DATA_PROTECTION
	bool
	default y if BT_ACS_DATA_PROTECTION_AES_GCM || BT_ACS_DATA_PROTECTION_AES_CCM || \
		     BT_ACS_DATA_PROTECTION_AES_GMAC || BT_ACS_DATA_PROTECTION_AES_CMAC

config BT_ACS_ISC_MAX_CONTROLS
	int
	default 3 if BT_ACS_FEAT_CONFIDENTIALITY || BT_ACS_DATA_PROTECTION_AES_GMAC
	default 1
	help
	  Maximum number of Information Security Controls entries
	  represented in a single ISC record for this implementation.

	  The value is derived from the active protection level:
	    Confidentiality or GMAC -> 3 (GCM/CCM/GMAC ISCs)
	    Otherwise               -> 1 (CMAC or Unencrypted ISCs)

config BT_ACS_HAS_NONCE_FIXED
	bool
	default y if BT_ACS_CCM_NONCE_SEQ_DIFF_FIXED
	default y if BT_ACS_DATA_PROTECTION_AES_GCM || BT_ACS_DATA_PROTECTION_AES_GMAC
	default n
	help
	  Hidden helper enabled when at least one selected
	  data-protection algorithm uses a nonce format with a
	  fixed part.

	  In this implementation, nonce-fixed values are stored per
	  key descriptor record, so no global nonce-fixed buffer-size
	  setting is needed.

choice BT_ACS_KEY_FORMAT
	prompt "Public key format"
	default BT_ACS_KEY_FORMAT_UNCOMPRESSED
	help
	  Select the public key format used by this implementation.

config BT_ACS_KEY_FORMAT_UNCOMPRESSED
	bool "Uncompressed plain"

config BT_ACS_KEY_FORMAT_X509
	bool "X.509"

config BT_ACS_KEY_FORMAT_MANUFACTURER
	bool "Manufacturer-specific"

endchoice

config BT_ACS_MULTIPLE_RESTRICTION_MAPS
	bool "Multiple restriction maps"
	help
	  Enable support for processing more than one Restriction Map
	  in this ACS implementation.

config BT_ACS_DESCRIPTORS
	bool "ACS descriptors"
	default y
	help
	  Enable support for ACS descriptor processing in this
	  implementation.

config BT_ACS_RESOURCE_HANDLE_UUID_MAP
	bool "Resource handle to UUID mapping"
	help
	  Enable support for mapping protected resource handles to
	  UUID values in this ACS implementation.

config BT_ACS_ATT_MTU
	bool "ATT MTU negotiation"
	help
	  Enable support for ATT MTU negotiation in this ACS
	  implementation.

config BT_ACS_PROTECTED_RESOURCE_WRITE
	bool "Protected resource write"
	default y
	help
	  Enable ACS protection checks for writes to protected
	  resources.

config BT_ACS_PROTECTED_RESOURCE_READ
	bool "Protected resource read"
	default y
	select BT_ACS_PROTECTED_RESOURCE_WRITE
	select BT_ACS_PROTECTED_RESOURCE_NOTIFICATION
	help
	  Enable ACS protection checks for reads from protected
	  resources.

config BT_ACS_PROTECTED_RESOURCE_NOTIFICATION
	bool "Protected resource notification"
	help
	  Enable ACS protection checks for notifications from
	  protected resources.

config BT_ACS_PROTECTED_RESOURCE_INDICATION
	bool "Protected resource indication"
	help
	  Enable ACS protection checks for indications from
	  protected resources.

config BT_ACS_MAX_SEGMENT_SIZE
	int "Maximum reassembled ACS message size"
	default 256
	range 64 2048
	help
	  Maximum size, in bytes, of a reassembled ACS message
	  (after all segments are joined).  Sizes the shared
	  buffer pool; each buffer is this value plus crypto
	  overhead (auth tag + nonce).

	  The default of 256 covers the full single-segment
	  payload at ATT_MTU 247 (the common DLE negotiation).
	  Raise to 512 for ATT_MTU 517 (BT 5.x extended).

# Hidden: scratch PDU payload size embedded in every acs_seg_tx_ctx.
# Sized to the largest outbound segment the server will place on the wire in
# one ATT indication. Kept hidden because raising it grows every per-connection
# TX context; lower only on RAM-tight targets with short MTUs.
config BT_ACS_SEG_TX_SCRATCH_PAYLOAD
	int
	default 64

config BT_ACS_CP_BUF_SIZE
	int "Control Point buffer size"
	default 256
	range 64 1024
	help
	  Size, in bytes, of the buffer used for ACS Control Point
	  responses in this implementation.

config BT_ACS_MAX_INFLIGHT_REQ_PER_CONN
	int "Maximum in-flight ACS requests per connection"
	default 4
	range 1 8
	help
	  Maximum number of ACS data requests that can remain active
	  at the same time on a single connection.

	  Completed requests are copied into request contexts so new
	  requests can still be admitted while earlier responses are
	  waiting to be sent.

config BT_ACS_WORKQUEUE_STACK_SIZE
	int "ACS workqueue stack size"
	default 2048
	range 1024 8192
	help
	  Stack size, in bytes, of the dedicated ACS workqueue used
	  for protected-request handling and segmented Data Out
	  continuation.

config BT_ACS_WORKQUEUE_THREAD_PRIO
	int "ACS workqueue thread priority"
	default 3
	help
	  Scheduling priority of the dedicated ACS workqueue used
	  for protected-request handling and segmented Data Out
	  continuation.

config BT_ACS_GATT_AUTHORIZATION
	bool "Auto-register GATT authorization callback"
	default y
	depends on BT_GATT_AUTHORIZATION_CUSTOM
	depends on BT_ACS_FEAT_AUTHORIZATION
	help
	  Automatically register a bt_gatt_authorization_cb during
	  initialization for ACS-protected GATT access.

	  When enabled, this implementation blocks reads and writes
	  to protected attributes until the required ACS security
	  has been established.

	  Use this option when services declare protection through
	  BT_ACS_RMAP_PROTECT_CHAR_IN_MAP() and use
	  BT_ACS_GATT_PERM_READ or BT_ACS_GATT_PERM_WRITE on the
	  corresponding attributes.

	  Disable this option if the application registers its own
	  GATT authorization callback and calls
	  bt_acs_is_operation_permitted() from that callback path.

config BT_ACS_MAX_PROTECTED_CCCD_GATES
	int "Maximum protected CCCD gate entries"
	default 8
	range 1 64
	depends on BT_ACS_GATT_AUTHORIZATION
	help
	  Maximum number of protected Client Characteristic
	  Configuration Descriptor entries cached for automatic
	  ACS GATT authorization.

	  Size this value to at least the number of distinct
	  protected characteristics in the Restriction Maps that
	  use notify or indicate permissions.

endif # BT_ACS
